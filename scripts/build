#!/usr/bin/env bash
#
# Environment Variables:
#   GOPRIVATE    - Comma-separated list of Go module patterns to treat as private
#                  (default: github.com/anthropics/anthropic-sdk-go,github.com/stainless-sdks/anthropic-go)
#

set -euo pipefail

cd "$(dirname "$0")/.."

export GOPRIVATE="${GOPRIVATE:+$GOPRIVATE,}github.com/anthropics/anthropic-sdk-go,github.com/stainless-sdks/anthropic-go"

echo "==> Building ant binary"
go build -o ./bin/ant ./cmd/ant
